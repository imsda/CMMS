generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  CLUB_DIRECTOR
  STAFF_TEACHER
  STUDENT_PARENT
}

enum ClubType {
  PATHFINDER
  ADVENTURER
  EAGER_BEAVER
}

enum MemberRole {
  PATHFINDER
  ADVENTURER
  TLT
  STAFF
  CHILD
  DIRECTOR
  COUNSELOR
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  WALK_IN
}

enum RolloverStatus {
  CONTINUING
  ARCHIVED
  GRADUATED
  NEW
}

enum RegistrationStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  NEEDS_CHANGES
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum EventMode {
  BASIC_FORM
  CLUB_REGISTRATION
  CLASS_ASSIGNMENT
}

enum EventWorkflowType {
  STANDARD
  CAMPOREE
}

enum EventTemplateCategory {
  BASIC_EVENTS
  CLUB_REGISTRATION
  CLASS_ASSIGNMENT
  MONTHLY_REPORTS
}

enum EventTemplateSource {
  SYSTEM
  USER
}

enum FormFieldType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  BOOLEAN
  DATE
  SINGLE_SELECT
  MULTI_SELECT
  ROSTER_SELECT
  ROSTER_MULTI_SELECT
  FIELD_GROUP
}

enum FormFieldScope {
  GLOBAL
  ATTENDEE
}

enum ClassType {
  HONOR
  SPECIALTY
  WORKSHOP
  REQUIRED
}

enum RequirementType {
  MIN_AGE
  MAX_AGE
  MEMBER_ROLE
  COMPLETED_HONOR
  MASTER_GUIDE
}

enum ReportStatus {
  DRAFT
  SUBMITTED
}

enum MonthlyReportStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REVISION_REQUESTED
}

enum NominationStatus {
  SUBMITTED
  REVIEWED
  WINNER
}

enum TltApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TltRecommendationStatus {
  PENDING
  COMPLETED
}

enum TltRecommendationInviteEmailStatus {
  PENDING
  SENT
  FAILED
}

enum ComplianceSyncRunStatus {
  PREVIEW
  APPLIED
}

enum ComplianceSyncScope {
  ROSTER_YEAR
  SYSTEM_WIDE
}

enum AuthRateLimitScope {
  EMAIL_IP
  IP
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  name                  String
  role                  UserRole
  passwordHash          String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  memberships           ClubMembership[]
  taughtOfferings       EventClassOffering[] @relation("OfferingTeacher")
  completedRequirements MemberRequirement[]
  complianceSyncRuns    ComplianceSyncRun[]
  appliedComplianceSyncRuns ComplianceSyncRun[] @relation("ComplianceSyncRunAppliedBy")
  rosterMemberLinks     UserRosterMemberLink[]
  eventTemplatesCreated EventTemplate[]
  camporeeScoresCreated CamporeeScore[]
  monthlyReportsSubmitted MonthlyReport[]      @relation("MonthlyReportSubmittedBy")
  monthlyReportsReviewed  MonthlyReport[]      @relation("MonthlyReportReviewedBy")
  reviewedEventRegistrations EventRegistration[] @relation("EventRegistrationReviewedBy")
  auditLogs             AuditLog[]
}

model Club {
  id              String              @id @default(cuid())
  name            String
  code            String              @unique
  type            ClubType
  city            String?
  state           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  memberships     ClubMembership[]
  rosterYears     ClubRosterYear[]
  registrations   EventRegistration[]
  monthlyReports  MonthlyReport[]
  yearEndReports  YearEndReport[]
  nominations     Nomination[]
  tltApplications TltApplication[]
  complianceSyncRuns ComplianceSyncRun[]
  auditLogs       AuditLog[]
}

model ClubMembership {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  title     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
}

model ClubRosterYear {
  id               String           @id @default(cuid())
  clubId           String
  yearLabel        String
  startsOn         DateTime
  endsOn           DateTime
  isActive         Boolean          @default(true)
  copiedFromYearId String?
  createdAt        DateTime         @default(now())

  club             Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  copiedFromYear   ClubRosterYear?  @relation("RosterYearRollover", fields: [copiedFromYearId], references: [id])
  rolledIntoYears  ClubRosterYear[] @relation("RosterYearRollover")
  members          RosterMember[]
  clubActivities   ClubActivity[]
  monthlyReports   MonthlyReport[]
  complianceSyncRuns ComplianceSyncRun[]
  auditLogs        AuditLog[]

  @@unique([clubId, yearLabel])
  @@index([clubId, isActive])
}

model ClubActivity {
  id                    String         @id @default(cuid())
  clubRosterYearId      String
  activityDate          DateTime
  title                 String
  pathfinderAttendance  Int
  staffAttendance       Int
  uniformCompliance     Int
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  clubRosterYear ClubRosterYear @relation(fields: [clubRosterYearId], references: [id], onDelete: Cascade)

  @@index([clubRosterYearId, activityDate])
}

model RosterMember {
  id                         String                @id @default(cuid())
  clubRosterYearId           String
  firstName                  String
  lastName                   String
  dateOfBirth                DateTime?
  ageAtStart                 Int?
  gender                     Gender?
  memberRole                 MemberRole
  medicalFlags               String?
  dietaryRestrictions        String?
  isFirstTime                Boolean               @default(false)
  isMedicalPersonnel         Boolean               @default(false)
  masterGuide                Boolean               @default(false)
  backgroundCheckDate        DateTime?
  backgroundCheckCleared     Boolean               @default(false)
  memberStatus               MemberStatus          @default(ACTIVE)
  rolloverStatus             RolloverStatus        @default(CONTINUING)
  isActive                   Boolean               @default(true)
  emergencyContactName       String?
  emergencyContactPhone      String?
  insuranceCompany           String?
  insurancePolicyNumber      String?
  insuranceCardFilename      String?
  lastTetanusDate            DateTime?
  lastTetanusDateEncrypted   String?
  photoReleaseConsent        Boolean               @default(false)
  medicalTreatmentConsent    Boolean               @default(false)
  membershipAgreementConsent Boolean               @default(false)
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  clubRosterYear         ClubRosterYear        @relation(fields: [clubRosterYearId], references: [id], onDelete: Cascade)
  registrations          RegistrationAttendee[]
  classEnrollments       ClassEnrollment[]
  completedRequirements  MemberRequirement[]
  eventFormResponses     EventFormResponse[]
  nominations            Nomination[]
  tltApplication         TltApplication?
  portalUsers            UserRosterMemberLink[]

  @@index([clubRosterYearId, isActive])
  @@index([lastName, firstName])
}

model UserRosterMemberLink {
  id             String   @id @default(cuid())
  userId         String
  rosterMemberId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rosterMember RosterMember @relation(fields: [rosterMemberId], references: [id], onDelete: Cascade)

  @@unique([userId, rosterMemberId])
  @@index([rosterMemberId])
}

model TltApplication {
  id               String               @id @default(cuid())
  rosterMemberId   String               @unique
  clubId           String
  grade            Int
  citizenship      String
  isBaptized       Boolean
  tltYearWorkingOn Int
  schoolName       String
  schoolAddress    String
  classesCompleted Json
  tShirtSize       String
  poloSize         String
  status           TltApplicationStatus @default(PENDING)
  createdAt        DateTime             @default(now())

  rosterMember     RosterMember         @relation(fields: [rosterMemberId], references: [id], onDelete: Cascade)
  club             Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  recommendations  TltRecommendation[]

  @@index([clubId, status])
}

model TltRecommendation {
  id                     String                               @id @default(cuid())
  tltApplicationId       String
  secureToken            String                               @unique
  recommenderName        String?
  recommenderEmail       String
  relationship           String?
  qualities              String?
  stressResponse         String?
  potentialProblems      String?
  status                 TltRecommendationStatus              @default(PENDING)
  inviteEmailStatus      TltRecommendationInviteEmailStatus   @default(PENDING)
  inviteEmailSentAt      DateTime?
  inviteEmailError       String?
  submittedAt            DateTime?
  createdAt              DateTime                             @default(now())
  updatedAt              DateTime                             @updatedAt

  tltApplication TltApplication @relation(fields: [tltApplicationId], references: [id], onDelete: Cascade)

  @@index([tltApplicationId])
  @@index([status])
  @@index([inviteEmailStatus])
}

model Nomination {
  id                      String           @id @default(cuid())
  clubId                  String
  rosterMemberId          String
  awardType               String
  year                    Int
  justificationText       String
  communityServiceDetails String
  status                  NominationStatus @default(SUBMITTED)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  club         Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  rosterMember RosterMember @relation(fields: [rosterMemberId], references: [id], onDelete: Cascade)

  @@index([clubId, year])
  @@index([status])
}

model Event {
  id                   String               @id @default(cuid())
  name                 String
  slug                 String               @unique
  eventMode            EventMode            @default(CLUB_REGISTRATION)
  workflowType         EventWorkflowType    @default(STANDARD)
  description          String?
  startsAt             DateTime
  endsAt               DateTime
  registrationOpensAt  DateTime
  registrationClosesAt DateTime
  basePrice            Float
  lateFeePrice         Float
  lateFeeStartsAt      DateTime
  locationName         String?
  locationAddress      String?
  createdByUserId      String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  dynamicFields  EventFormField[]
  registrations  EventRegistration[]
  classTimeslots EventClassTimeslot[]
  classOfferings EventClassOffering[]
  classPreferences EventClassPreference[]
  classWaitlistEntries EventClassWaitlist[]
  camporeeScores CamporeeScore[]
}

model EventTemplate {
  id              String                @id @default(cuid())
  templateKey     String?               @unique
  name            String
  description     String?
  eventMode       EventMode             @default(CLUB_REGISTRATION)
  category        EventTemplateCategory @default(BASIC_EVENTS)
  source          EventTemplateSource   @default(USER)
  isActive        Boolean               @default(true)
  archivedAt      DateTime?
  snapshot        Json
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  createdBy User @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([isActive, updatedAt])
  @@index([createdByUserId, updatedAt])
  @@index([source, category, isActive, updatedAt])
}

model EventFormField {
  id            String           @id @default(cuid())
  eventId       String
  parentFieldId String?
  key           String
  label         String
  description   String?
  type          FormFieldType
  fieldScope    FormFieldScope   @default(GLOBAL)
  options       Json?
  isRequired    Boolean          @default(false)
  sortOrder     Int              @default(0)

  event         Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parentField   EventFormField?  @relation("EventFormFieldHierarchy", fields: [parentFieldId], references: [id], onDelete: Cascade)
  childFields   EventFormField[] @relation("EventFormFieldHierarchy")
  responses     EventFormResponse[]

  @@unique([eventId, key])
  @@index([eventId, sortOrder])
  @@index([eventId, parentFieldId])
}

model EventRegistration {
  id                    String             @id @default(cuid())
  eventId               String
  clubId                String
  registrationCode      String             @unique
  status                RegistrationStatus @default(DRAFT)
  submittedAt           DateTime?
  approvedAt            DateTime?
  reviewedAt            DateTime?
  reviewedByUserId      String?
  overrideLimitsAllowed Boolean            @default(false)
  notes                 String?
  reviewerNotes         String?
  revisionRequestedReason String?
  totalDue              Float
  amountPaid            Float              @default(0)
  paymentStatus         PaymentStatus      @default(PENDING)
  squarePaymentId       String?
  squareCheckoutUrl     String?
  squareOrderId         String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  event         Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  club          Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  reviewedByUser User?               @relation("EventRegistrationReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  attendees     RegistrationAttendee[]
  formResponses EventFormResponse[]
  camporeeScores CamporeeScore[]
  camporeeRegistration CamporeeRegistration?

  @@unique([eventId, clubId])
  @@index([clubId, status])
  @@index([reviewedByUserId])
}

model CamporeeRegistration {
  id                         String   @id @default(cuid())
  eventRegistrationId        String   @unique
  primaryContactName         String
  primaryContactPhone        String
  primaryContactEmail        String?
  secondaryContactName       String?
  secondaryContactPhone      String?
  campsiteType              String
  tentSummary               String
  trailerCount              Int      @default(0)
  kitchenCanopyCount        Int      @default(0)
  squareFootageNeeded       Int      @default(0)
  campNearRequest           String?
  campsiteNotes             String?
  arrivalDateTime           DateTime?
  departureDateTime         DateTime?
  vehicleCount              Int      @default(0)
  transportSummary          String?
  arrivalNotes              String?
  mealPlan                  String
  sabbathSupperCount        Int      @default(0)
  sundayBreakfastCount      Int      @default(0)
  waterServiceNeeded        Boolean  @default(false)
  foodPlanningNotes         String?
  dietaryNotes              String?
  dutyPreferences           String[]
  participationHighlights   String[]
  firstAidCertifiedCount    Int      @default(0)
  leadershipStaffCount      Int      @default(0)
  emergencyContactName      String
  emergencyContactPhone     String
  emergencyMeetingPoint     String?
  medicationStorageNotes    String?
  emergencyNotes            String?
  chaplainVisitRequested    Boolean  @default(false)
  worshipParticipationNotes String?
  ministryDisplayNotes      String?
  finalReviewNotes          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  registration EventRegistration @relation(fields: [eventRegistrationId], references: [id], onDelete: Cascade)
}

model CamporeeScore {
  id                  String   @id @default(cuid())
  eventId             String
  eventRegistrationId String
  category            String
  score               Float
  notes               String?
  createdByUserId     String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  event        Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration EventRegistration @relation(fields: [eventRegistrationId], references: [id], onDelete: Cascade)
  createdBy    User              @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([eventRegistrationId, category])
  @@index([eventId, category, score])
  @@index([createdByUserId, createdAt])
}

model RegistrationAttendee {
  id                  String   @id @default(cuid())
  eventRegistrationId String
  rosterMemberId      String
  checkedInAt         DateTime?
  createdAt           DateTime @default(now())

  eventRegistration EventRegistration @relation(fields: [eventRegistrationId], references: [id], onDelete: Cascade)
  rosterMember      RosterMember      @relation(fields: [rosterMemberId], references: [id], onDelete: Cascade)
  classPreferences  EventClassPreference[]
  classWaitlistEntries EventClassWaitlist[]

  @@unique([eventRegistrationId, rosterMemberId])
  @@index([rosterMemberId])
}

model EventClassTimeslot {
  id          String   @id @default(cuid())
  eventId     String
  label       String
  startsAt    DateTime
  endsAt      DateTime
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event        Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  offerings    EventClassOffering[]
  preferences  EventClassPreference[]
  waitlistEntries EventClassWaitlist[]

  @@unique([eventId, label])
  @@index([eventId, sortOrder])
  @@index([eventId, active, sortOrder])
}

model ClassCatalog {
  id          String   @id @default(cuid())
  title       String
  code        String   @unique
  description String?
  classType   ClassType
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requirements ClassRequirement[]
  offerings    EventClassOffering[]
}

model ClassRequirement {
  id              String          @id @default(cuid())
  classCatalogId  String
  requirementType RequirementType
  config          Json

  classCatalog ClassCatalog @relation(fields: [classCatalogId], references: [id], onDelete: Cascade)

  @@index([classCatalogId])
}

model EventClassOffering {
  id             String   @id @default(cuid())
  eventId        String
  timeslotId     String?
  classCatalogId String
  teacherUserId  String?
  capacity       Int?
  locationName   String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  event        Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timeslot     EventClassTimeslot? @relation(fields: [timeslotId], references: [id], onDelete: SetNull)
  classCatalog ClassCatalog     @relation(fields: [classCatalogId], references: [id], onDelete: Cascade)
  teacher      User?            @relation("OfferingTeacher", fields: [teacherUserId], references: [id], onDelete: SetNull)
  enrollments  ClassEnrollment[]
  preferences  EventClassPreference[]
  waitlistEntries EventClassWaitlist[]

  @@unique([eventId, classCatalogId, timeslotId])
  @@index([timeslotId, active])
  @@index([teacherUserId])
}

model ClassEnrollment {
  id                   String   @id @default(cuid())
  eventClassOfferingId String
  rosterMemberId       String
  assignedAt           DateTime @default(now())
  attendedAt           DateTime?

  offering     EventClassOffering @relation(fields: [eventClassOfferingId], references: [id], onDelete: Cascade)
  rosterMember RosterMember       @relation(fields: [rosterMemberId], references: [id], onDelete: Cascade)

  @@unique([eventClassOfferingId, rosterMemberId])
  @@index([rosterMemberId])
}

model EventClassPreference {
  id                     String   @id @default(cuid())
  eventId                String
  timeslotId             String
  registrationAttendeeId String
  eventClassOfferingId   String
  rank                   Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  event                Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timeslot             EventClassTimeslot  @relation(fields: [timeslotId], references: [id], onDelete: Cascade)
  registrationAttendee RegistrationAttendee @relation(fields: [registrationAttendeeId], references: [id], onDelete: Cascade)
  offering             EventClassOffering  @relation(fields: [eventClassOfferingId], references: [id], onDelete: Cascade)

  @@unique([timeslotId, registrationAttendeeId, rank])
  @@unique([timeslotId, registrationAttendeeId, eventClassOfferingId])
  @@index([eventId, timeslotId])
  @@index([eventClassOfferingId, rank])
  @@index([registrationAttendeeId, timeslotId])
}

model EventClassWaitlist {
  id                     String   @id @default(cuid())
  eventId                String
  timeslotId             String
  registrationAttendeeId String
  eventClassOfferingId   String
  position               Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  event                Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timeslot             EventClassTimeslot   @relation(fields: [timeslotId], references: [id], onDelete: Cascade)
  registrationAttendee RegistrationAttendee @relation(fields: [registrationAttendeeId], references: [id], onDelete: Cascade)
  offering             EventClassOffering   @relation(fields: [eventClassOfferingId], references: [id], onDelete: Cascade)

  @@unique([timeslotId, registrationAttendeeId])
  @@unique([eventClassOfferingId, registrationAttendeeId])
  @@unique([eventClassOfferingId, position])
  @@index([eventId, timeslotId])
  @@index([registrationAttendeeId, timeslotId])
}

model MemberRequirement {
  id              String          @id @default(cuid())
  userId          String
  rosterMemberId  String?
  requirementType RequirementType
  metadata        Json?
  completedAt     DateTime
  createdAt       DateTime        @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rosterMember RosterMember? @relation(fields: [rosterMemberId], references: [id], onDelete: SetNull)

  @@index([userId, requirementType])
  @@index([rosterMemberId, requirementType])
}

model ComplianceSyncRun {
  id               String                  @id @default(cuid())
  uploadedByUserId String
  appliedByUserId  String?
  scope            ComplianceSyncScope     @default(ROSTER_YEAR)
  clubId           String?
  clubRosterYearId String?
  fileName         String
  status           ComplianceSyncRunStatus @default(PREVIEW)
  processedRows    Int
  passedRows       Int
  updateCount      Int
  skippedCount     Int
  ambiguousCount   Int
  rowResults       Json
  appliedAt        DateTime?
  createdAt        DateTime                @default(now())

  uploadedBy      User            @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  appliedBy       User?           @relation("ComplianceSyncRunAppliedBy", fields: [appliedByUserId], references: [id], onDelete: SetNull)
  club            Club?           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  clubRosterYear  ClubRosterYear? @relation(fields: [clubRosterYearId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
  @@index([clubRosterYearId, createdAt])
  @@index([scope, createdAt])
  @@index([uploadedByUserId, createdAt])
  @@index([appliedByUserId, createdAt])
}

model AuditLog {
  id               String   @id @default(cuid())
  actorUserId      String?
  actorRole        UserRole?
  action           String
  targetType       String
  targetId         String?
  clubId           String?
  clubRosterYearId String?
  summary          String
  metadata         Json?
  createdAt        DateTime @default(now())

  actor          User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  club           Club?           @relation(fields: [clubId], references: [id], onDelete: SetNull)
  clubRosterYear ClubRosterYear? @relation(fields: [clubRosterYearId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, createdAt])
  @@index([clubId, createdAt])
  @@index([clubRosterYearId, createdAt])
}

model ScheduledJobRun {
  id          String   @id @default(cuid())
  jobKey      String
  scopeKey    String
  runDate     DateTime
  status      String
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@unique([jobKey, scopeKey, runDate])
  @@index([jobKey, runDate])
  @@index([createdAt])
}

model AuthRateLimitBucket {
  keyHash       String             @id
  scopeType     AuthRateLimitScope
  attemptCount  Int
  windowStartedAt DateTime
  blockedUntil  DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([scopeType, updatedAt])
  @@index([blockedUntil])
}

model EventFormResponse {
  id                  String   @id @default(cuid())
  eventRegistrationId String
  eventFormFieldId    String
  attendeeId          String?
  value               Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  registration EventRegistration @relation(fields: [eventRegistrationId], references: [id], onDelete: Cascade)
  field        EventFormField    @relation(fields: [eventFormFieldId], references: [id], onDelete: Cascade)
  attendee     RosterMember?     @relation(fields: [attendeeId], references: [id], onDelete: SetNull)

  @@index([eventRegistrationId])
  @@index([eventFormFieldId])
  @@index([attendeeId])
  @@unique([eventRegistrationId, eventFormFieldId, attendeeId])
}

model MonthlyReport {
  id                           String                @id @default(cuid())
  clubId                       String
  clubRosterYearId             String?
  reportMonth                  DateTime
  meetingDay                   String?
  meetingTime                  String?
  meetingLocation              String?
  averageAttendance            Int                   @default(0)
  averagePathfinderAttendance  Int                   @default(0)
  averageTltAttendance         Int                   @default(0)
  averageStaffAttendance       Int                   @default(0)
  pathfinderCount              Int                   @default(0)
  tltCount                     Int                   @default(0)
  staffCount                   Int                   @default(0)
  staffMeetingHeld             Boolean               @default(false)
  meetingOutingCount           Int                   @default(0)
  devotionsEmphasis            String?
  exercisePromotion            String?
  outreachActivities           String?
  guestHelperCount             Int                   @default(0)
  uniformCompliance            Int                   @default(0)
  uniformNotes                 String?
  honorWorkSummary             String?
  honorParticipantCount        Int                   @default(0)
  bonusNotes                   String?
  submittedByName              String?
  submittedByUserId            String?
  signedAt                     DateTime?
  status                       MonthlyReportStatus   @default(DRAFT)
  totalScore                   Int                   @default(0)
  adminComments                String?
  revisionRequestedReason      String?
  submittedAt                  DateTime?
  reviewedAt                   DateTime?
  reviewedByUserId             String?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt

  club             Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  clubRosterYear   ClubRosterYear?         @relation(fields: [clubRosterYearId], references: [id], onDelete: SetNull)
  submittedByUser  User?                   @relation("MonthlyReportSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  reviewedByUser   User?                   @relation("MonthlyReportReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  scoreLineItems   MonthlyReportScoreLineItem[]

  @@unique([clubId, reportMonth])
  @@index([reportMonth])
  @@index([status])
  @@index([clubRosterYearId])
  @@index([submittedByUserId])
  @@index([reviewedByUserId])
}

model MonthlyReportScoreLineItem {
  id              String        @id @default(cuid())
  monthlyReportId String
  key             String
  label           String
  points          Int
  maxPoints       Int
  sortOrder       Int
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  monthlyReport MonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)

  @@index([monthlyReportId, sortOrder])
  @@unique([monthlyReportId, key])
}

model YearEndReport {
  id                 String       @id @default(cuid())
  clubId             String
  reportYear         Int
  friendCompletions  Int          @default(0)
  companionCompletions Int        @default(0)
  explorerCompletions Int         @default(0)
  rangerCompletions  Int          @default(0)
  voyagerCompletions Int          @default(0)
  guideCompletions   Int          @default(0)
  status             ReportStatus @default(DRAFT)
  submittedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, reportYear])
  @@index([reportYear])
  @@index([status])
}
