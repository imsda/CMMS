{
  "name": "cmms",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts tests/*.integration.test.ts",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build",
    "backfill:medical-encryption": "tsx prisma/backfill-medical-encryption.ts",
    "cleanup:auth-rate-limits": "tsx prisma/cleanup-auth-rate-limits.ts",
    "audit:email-normalization": "tsx prisma/audit-user-email-normalization.ts",
    "check:startup": "NODE_ENV=production tsx scripts/run-startup-self-checks.ts",
    "verify:docker": "sh scripts/verify-docker-compose.sh",
    "schedule:auth-rate-limit-cleanup": "sh scripts/run-auth-rate-limit-cleanup.sh",
    "schedule:jobs": "tsx scripts/run-scheduled-jobs.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "^4.3.1",
    "bcryptjs": "^2.4.3",
    "next": "^15.5.10",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^3.26.4",
    "prisma": "^5.22.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
