# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cmms?schema=public"

# Auth
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SECRET="replace-with-the-same-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security / encryption
# Required in all environments. Existing plaintext medical fields must be backfilled after deploy.
MEDICAL_ENCRYPTION_KEY="replace-with-a-32-byte-base64-or-hex-key"

# Consent document versioning
# Set to the version identifier of the current waiver/consent document (e.g. "2025-v1").
# Stored on RosterMember when consent is recorded so you can track which version was agreed to.
CONSENT_DOCUMENT_VERSION="2025-v1"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="CMMS <noreply@example.org>"
CONFERENCE_CONTACT_EMAIL="conference@example.org"

# Square Payments
# SQUARE_ACCESS_TOKEN: Bearer token from the Square Developer Dashboard (Applications > Credentials).
SQUARE_ACCESS_TOKEN="your-square-access-token-here"
# SQUARE_ENVIRONMENT: "sandbox" for testing, "production" for live payments.
SQUARE_ENVIRONMENT="sandbox"
# SQUARE_LOCATION_ID: The Square location ID to associate with payment links and orders.
SQUARE_LOCATION_ID="XXXXXXXXXXXXXXXX"
# SQUARE_WEBHOOK_SIGNATURE_KEY: Signature key from the Square Developer Dashboard
# (Webhooks > your endpoint > Signature key). Used to verify incoming webhook payloads.
SQUARE_WEBHOOK_SIGNATURE_KEY="replace-with-square-webhook-signature-key"

# Seed overrides (optional)
SEED_SUPER_ADMIN_EMAIL="superadmin@cmms.local"
SEED_SUPER_ADMIN_PASSWORD="ChangeMeNow123!"
SEED_SUPER_ADMIN_NAME="CMMS Super Admin"
